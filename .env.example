# Copy this file to .env and replace all REPLACE_ME values before deployment.
# .env is ignored by Git.

# Shared
RESOURCE_GROUP=aca-learning-rg
ACA_ENV_NAME=aca-learning-env
ACR_NAME=yourregistry

# hello-api settings
APP_NAME=hello-api
APP_SECURITY_USERNAME=acauser
APP_SECURITY_PASSWORD=REPLACE_ME_STRONG_PASSWORD
APP_JWT_SECRET=REPLACE_ME_32_PLUS_CHAR_SECRET
APP_JWT_EXPIRATION=3600000

# APISIX settings
GATEWAY_APP=apisix-gateway
HELLO_APP=hello-api
APISIX_ADMIN_KEY=REPLACE_ME_APISIX_ADMIN_KEY

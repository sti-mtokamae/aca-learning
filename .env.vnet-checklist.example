# VNet Migration Working Log Template
# コピーして .env.vnet-checklist として使用してください
# (cp .env.vnet-checklist.example .env.vnet-checklist)
# このファイルは公開版。.env.vnet-checklist は .gitignore で除外されます。

## Section 2: VNet導入前の現状固定 - 記録値

# 実施日
RUN_DATE=<YYYY-MM-DD>

# 実施者
RUN_USER=<YOUR_NAME>

# Azure 環境
RESOURCE_GROUP=<RESOURCE_GROUP>
ACA_ENV_NAME=<ACA_ENV_NAME>

# Container Apps
GATEWAY_APP=<GATEWAY_APP>
HELLO_APP=<HELLO_APP>

# FQDN（確認対象）
GATEWAY_FQDN=<GATEWAY_FQDN>

# APISIX Revision
APISIX_REVISION=<APISIX_REVISION>

## Section 3: ネットワーク境界の目標状態 - 設定値

# VNet構成（新規作成時の名前）
VNET_NAME=<VNET_NAME>
SUBNET_NAME=<SUBNET_NAME>
NSG_NAME=<NSG_NAME>

# VNet の CIDR（PoC例）
VNET_CIDR=<VNET_CIDR>
SUBNET_CIDR=<SUBNET_CIDR>

# ストレージアカウント（将来の接続対象、オプション）
STORAGE_ACCOUNT_NAME=
STORAGE_FILE_SHARE=

## Section 4: VNet適用後 - 新環境定義

# 新規 ACA Environment（VNet統合版）
NEW_ACA_ENV_NAME=<NEW_ACA_ENV_NAME>
NEW_GATEWAY_APP=<NEW_GATEWAY_APP>
NEW_HELLO_APP=<NEW_HELLO_APP>

# デプロイ時のタグ
VNET_VERSION=<VNET_VERSION>
DEPLOYMENT_DATE=<DEPLOYMENT_DATE>

# VNet Migration Working Log Template
# コピーして .env.vnet-checklist として使用してください
# (cp .env.vnet-checklist.example .env.vnet-checklist)
# このファイルは公開版。.env.vnet-checklist は .gitignore で除外されます。

## Section 2: VNet導入前の現状固定 - 記録値

# 実施日
RUN_DATE=2026-04-04

# 実施者
RUN_USER=mtok

# Azure 環境
RESOURCE_GROUP=aca-test-env
ACA_ENV_NAME=aca-test-env

# Container Apps
GATEWAY_APP=apisix-gateway
HELLO_APP=hello-api

# FQDN（確認対象）
GATEWAY_FQDN=apisix-gateway.delightfulstone-17625bbb.japaneast.azurecontainerapps.io

# APISIX Revision
APISIX_REVISION=apisix-gateway--0000034

## Section 3: ネットワーク境界の目標状態 - 設定値

# VNet構成（新規作成時の名前）
VNET_NAME=aca-vnet
SUBNET_NAME=aca-subnet
NSG_NAME=aca-nsg

# VNet の CIDR（PoC例）
VNET_CIDR=10.0.0.0/16
SUBNET_CIDR=10.0.0.0/24

# ストレージアカウント（将来の接続対象、オプション）
STORAGE_ACCOUNT_NAME=
STORAGE_FILE_SHARE=

## Section 4: VNet適用後 - 新環境定義

# 新規 ACA Environment（VNet統合版）
NEW_ACA_ENV_NAME=aca-test-env-vnet
NEW_GATEWAY_APP=apisix-gateway-vnet
NEW_HELLO_APP=hello-api-vnet

# デプロイ時のタグ
VNET_VERSION=v1
DEPLOYMENT_DATE=
